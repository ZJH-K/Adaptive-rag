# Embedding service (OpenAI-compatible)
EMBEDDING_BASE_URL=https://api.siliconflow.cn/v1
EMBEDDING_API_KEY=
EMBEDDING_MODEL=BAAI/bge-m3
EMBEDDING_DIMENSION=1024
EMBEDDING_BATCH_SIZE=32
EMBEDDING_TIMEOUT_SECONDS=30.0

# OpenAI-compatible chat service. Verify the model is currently available to
# your provider account before external Smoke; this example is overrideable.
LLM_BASE_URL=https://api.deepseek.com
LLM_API_KEY=
LLM_MODEL=deepseek-chat
LLM_TIMEOUT_SECONDS=60.0
LLM_TEMPERATURE=0.1
# Enable response_format=json_object for providers that support JSON mode.
LLM_JSON_MODE_ENABLED=true

# Reranker service (SiliconFlow-compatible). Verify model availability before
# enabling the opt-in external Smoke.
RERANKER_ENABLED=false
RERANKER_BASE_URL=https://api.siliconflow.cn/v1
RERANKER_API_KEY=
RERANKER_MODEL=BAAI/bge-reranker-v2-m3
RERANKER_TIMEOUT_SECONDS=30.0
RERANK_TOP_K=5

# Retrieval pipeline
HYBRID_RETRIEVAL_ENABLED=true
DENSE_TOP_N=20
BM25_TOP_N=20
RETRIEVE_TOP_N=20
RRF_K=60

# Langfuse tracing (optional; disabled keeps the core workflow offline)
LANGFUSE_ENABLED=false
LANGFUSE_BASE_URL=https://cloud.langfuse.com
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_ENVIRONMENT=development
# Full question/answer capture is opt-in. Defaults record redacted markers.
LANGFUSE_CAPTURE_QUESTION=false
LANGFUSE_CAPTURE_ANSWER=false
LANGFUSE_MAX_TEXT_CHARS=200

# Chroma
CHROMA_PERSIST_DIR=./data/chroma
CHROMA_COLLECTION=technical_docs

# Documents API
KNOWLEDGE_BASE_ID=technical_docs
UPLOAD_MAX_BYTES=10485760
# Defaults resolve to the project knowledge directory and the operating-system
# temporary directory. Uncomment only to override them.
# KNOWLEDGE_ROOT=../knowledge
# UPLOAD_TEMP_DIR=./data/uploads/tmp

# Streamlit frontend (contains no provider credentials)
BACKEND_URL=http://127.0.0.1:8000
